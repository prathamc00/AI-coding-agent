# OpenAI Configuration (leave empty to use Ollama)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama Configuration (set OLLAMA_ENABLED=true to use local model)
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=auto

# Database & General
DATABASE_URL=sqlite:///./app.db
COMMAND_TIMEOUT_SECONDS=120
NEXT_PUBLIC_API_URL=http://localhost:8000
